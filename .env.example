# JARVIS Environment Configuration Template
# Copy this to .env and fill in your values

# ============================================
# GROQ API CONFIGURATION
# ============================================
# Get your API key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ============================================
# VOICE CONFIGURATION (Optional)
# ============================================
# Wake word to activate voice listening
WAKE_WORD=jarvis

# Voice engine: pyttsx3 or edge-tts
VOICE_ENGINE=pyttsx3

# Speech rate in words per minute
VOICE_RATE=150

# Voice volume (0.0-1.0)
VOICE_VOLUME=1.0

# ============================================
# AI BEHAVIOR
# ============================================
# Temperature affects response randomness (0.0-1.0, higher = more creative)
TEMPERATURE=0.7

# Maximum tokens in response
MAX_TOKENS=2048

# ============================================
# MEMORY STORAGE
# ============================================
# Database type: json or sqlite
MEMORY_DB_TYPE=json

# Memory file location
MEMORY_FILE=jarvis_memory.json

# Clipboard history file
CLIPBOARD_HISTORY_FILE=clipboard_history.json

# Log file location
LOG_FILE=jarvis_log.txt

# Enable action logging
ENABLE_LOGGING=true

# ============================================
# FEATURE FLAGS
# ============================================
# Enable debug mode
DEBUG=false

# Print streaming responses in real-time
PRINT_STREAM=true

# Enable voice features
ENABLE_VOICE=false

# ============================================
# SAFETY SETTINGS
# ============================================
# Ask for confirmation on sensitive actions
CONFIRMATION_ENABLED=true

# Response timeout in seconds
RESPONSE_TIMEOUT=30

# Voice recognition timeout in seconds
VOICE_TIMEOUT=10
